# ⚙️ Configuración para desarrollo

# Puerto del servidor
PORT=5000

# *** OPCIÓN A: MongoDB Atlas (Cloud) *** ⭐ RECOMENDADO
# Reemplaza: hotel_admin con tu usuario, PASSWORD con tu contraseña, xxxxx con tu cluster ID
# MONGO_URI=mongodb+srv://hotel_admin:PASSWORD@cluster0.xxxxx.mongodb.net/hotel_final?retryWrites=true&w=majority

# *** OPCIÓN B: MongoDB Local ***
# MONGO_URI=mongodb://127.0.0.1:27017/hotel_final

# Por ahora, usa MongoDB Atlas. Una vez tengas la URI, descomenta la línea de OPCIÓN A
